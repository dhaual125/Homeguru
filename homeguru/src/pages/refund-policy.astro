---
import Layout from '../layouts/Layout.astro';
import HeaderNew from '../components/HeaderNew';
import FooterNew from '../components/FooterNew';
---

<Layout title="Refund Policy | HomeGuru">
  <HeaderNew client:load />

  <main class="flex-1 bg-[#fafafa]" style="font-family: Matter, sans-serif;">

    {/* Hero strip */}
    <section class="relative pt-36 pb-16 flex flex-col items-center text-center overflow-hidden">
      {/* Background glow */}
      <div
        class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[500px] h-[300px] blur-[100px] opacity-30 pointer-events-none"
        style="background: radial-gradient(ellipse, #A5BBFC 0%, #D5E2FF 40%, transparent 70%);"
        aria-hidden="true"
      />

      <div class="relative z-10 flex flex-col items-center gap-4 w-[85%] md:w-9/12 max-w-[860px] mx-auto">
        <span
          class="font-matter text-[11px] font-semibold uppercase tracking-[3px] px-4 py-1.5 rounded-full"
          style="color:#F97316; background:rgba(249,115,22,0.08); border:1px solid rgba(249,115,22,0.15);"
        >
          Legal
        </span>
        <h1 class="font-season-mix text-4xl md:text-[56px] leading-[1.1] tracking-tight text-[#111]">
          Refund Policy
        </h1>
        <p class="font-matter text-[#888] text-base md:text-lg leading-relaxed max-w-lg">
          At HomeGuru, we believe in full transparency and clarity when it comes to payments. Please read the policy carefully before proceeding with any transaction.
        </p>
        <p class="font-matter text-xs text-[#bbb] mt-1">Last updated: 2025</p>
      </div>
    </section>

    {/* Content */}
    <section class="mx-auto w-[85%] md:w-9/12 max-w-[860px] pb-28 flex flex-col gap-6">

      {/* For Learners */}
      <div
        class="flex flex-col gap-5 p-8 md:p-10 rounded-[28px]"
        style="background:#F6F6F6; border:1px solid #EBEBEB;"
      >
        <div class="flex items-center gap-3">
          <div class="w-9 h-9 rounded-xl flex items-center justify-center flex-shrink-0" style="background:#6366F1;">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253"/>
            </svg>
          </div>
          <h2 class="font-season-mix text-2xl md:text-[30px] text-[#111] leading-tight">For Learners</h2>
        </div>

        <div class="flex flex-col gap-4 font-matter text-[#555] text-base leading-[1.8]">
          <p>All payments made towards course fees are <strong class="text-[#111] font-semibold">non-refundable</strong>.</p>
          <p>
            Once added, the amount will be securely stored in your HomeGuru wallet and can only be used to book classes with the tutors of your choice, at your convenience.
          </p>
          <p>
            We do not offer cash refunds under any circumstances. Instead, we ensure you get complete value by helping you utilize your paid balance for personalized, quality learning sessions.
          </p>
        </div>
      </div>

      {/* For Tutors */}
      <div
        class="flex flex-col gap-5 p-8 md:p-10 rounded-[28px]"
        style="background:#F6F6F6; border:1px solid #EBEBEB;"
      >
        <div class="flex items-center gap-3">
          <div class="w-9 h-9 rounded-xl flex items-center justify-center flex-shrink-0" style="background:#F97316;">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z"/>
            </svg>
          </div>
          <h2 class="font-season-mix text-2xl md:text-[30px] text-[#111] leading-tight">For Tutors</h2>
        </div>

        <div class="flex flex-col gap-4 font-matter text-[#555] text-base leading-[1.8]">
          <p>
            The <strong class="text-[#111] font-semibold">₹999</strong> is a one-time registration fee that is a <strong class="text-[#111] font-semibold">non-refundable</strong> amount that covers your profile listing on the HomeGuru platform for one academic year.
          </p>

          <div class="flex flex-col gap-3 mt-1">
            <p class="font-semibold text-[#111] text-sm uppercase tracking-[1.5px]">Please note:</p>
            <ul class="flex flex-col gap-2 pl-1">
              {[
                "This fee does not guarantee student leads or class bookings.",
                "Learners are free to browse, evaluate, and choose tutors based on their preferences.",
              ].map((item) => (
                <li class="flex items-start gap-3">
                  <span class="mt-2 w-1.5 h-1.5 rounded-full flex-shrink-0" style="background:#F97316;"></span>
                  <span>{item}</span>
                </li>
              ))}
            </ul>
          </div>

          <p>
            Our role is to provide you with a credible platform and visibility. Conversions depend on your profile strength, teaching quality, and engagement.
          </p>
        </div>
      </div>

      {/* Contact card */}
      <div
        class="flex flex-col sm:flex-row items-start sm:items-center justify-between gap-5 p-8 rounded-[28px]"
        style="background:#fff; border:1px solid #EBEBEB;"
      >
        <div class="flex flex-col gap-1">
          <p class="font-season-mix text-xl text-[#111]">Still have questions?</p>
          <p class="font-matter text-sm text-[#888]">We appreciate your understanding and look forward to supporting your journey on HomeGuru.</p>
        </div>
        <a
          href="mailto:support@homeguruworld.com"
          class="inline-flex items-center gap-2 font-matter font-semibold text-sm px-5 py-3 rounded-full flex-shrink-0 transition-opacity duration-200 hover:opacity-80"
          style="background:#111; color:#fff;"
        >
          <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/>
            <polyline points="22,6 12,13 2,6"/>
          </svg>
          support@homeguruworld.com
        </a>
      </div>

    </section>
  </main>

  <FooterNew client:load />
</Layout>
